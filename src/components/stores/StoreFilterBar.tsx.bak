"use client";

import { Search, X } from "lucide-react";
import { useMemo } from "react";

function cn(...classes: Array<string | false | null | undefined>) {
    return classes.filter(Boolean).join(" ");
}

export type FilterState = {
    addr1: string; // "전체" 포함
    addr2: string; // "" 가능
    category: string; // ✅ 추가
    q: string;
};

export default function StoreFilterBar(props: {
    value: FilterState;
    onChange: (next: FilterState) => void;
    addr1Options: string[];
    addr2Options: string[]; // "전체"는 여기서 넣지 않고 UI에서 처리
    categoryOptions: string[]; // ✅ 추가
    loading?: boolean;
}) {
    const { value, onChange } = props;

    const addr2Full = useMemo(() => ["", ...props.addr2Options], [props.addr2Options]);

    return (
        <div className="rounded-3xl border bg-white p-4 shadow-sm">
            {/* Search */}
            <div className="flex items-center gap-2 rounded-2xl border bg-gray-50 px-3 py-2">
                <Search className="h-4 w-4 text-gray-500" />
                <input
                    value={value.q}
                    onChange={(e) => onChange({ ...value, q: e.target.value })}
                    placeholder="상호/주소/업종/전화 검색"
                    className="w-full bg-transparent text-sm outline-none"
                />
                {value.q && (
                    <button
                        type="button"
                        className="grid h-7 w-7 place-items-center rounded-full hover:bg-gray-200"
                        aria-label="검색어 지우기"
                        onClick={() => onChange({ ...value, q: "" })}
                    >
                        <X className="h-4 w-4 text-gray-600" />
                    </button>
                )}
            </div>

            {/* Addr1 chips */}
            <div className="mt-4">
                <div className="text-xs font-semibold text-gray-700">지역(1차)</div>
                <div className="mt-2 flex flex-wrap gap-2">
                    {props.addr1Options.map((opt) => {
                        const active = value.addr1 === opt;
                        return (
                            <button
                                key={opt}
                                type="button"
                                disabled={props.loading}
                                onClick={() => onChange({ ...value, addr1: opt, addr2: "" })}
                                className={cn(
                                    "rounded-full px-3 py-2 text-xs transition",
                                    active
                                        ? "bg-gray-900 text-white"
                                        : "border bg-white text-gray-700 hover:bg-gray-50",
                                    props.loading && "opacity-60"
                                )}
                            >
                                {opt}
                            </button>
                        );
                    })}
                </div>
            </div>

            {/* Addr2 */}
            <div className="mt-4">
                <div className="flex items-center justify-between">
                    <div className="text-xs font-semibold text-gray-700">지역(2차)</div>
                    <div className="text-[11px] text-gray-500">
                        {value.addr1 === "전체"
                            ? "1차 지역을 먼저 선택하세요"
                            : "검색 결과 기반으로 자동 표시"}
                    </div>
                </div>

                <div className="mt-2 flex flex-wrap gap-2">
                    {addr2Full.length === 1 ? (
                        <div className="rounded-2xl border bg-gray-50 px-3 py-2 text-xs text-gray-500">
                            표시할 2차 지역이 없습니다.
                        </div>
                    ) : (
                        addr2Full.map((opt) => {
                            const label = opt === "" ? "전체" : opt;
                            const active = value.addr2 === opt;
                            return (
                                <button
                                    key={label}
                                    type="button"
                                    disabled={props.loading || value.addr1 === "전체"}
                                    onClick={() => onChange({ ...value, addr2: opt })}
                                    className={cn(
                                        "rounded-full px-3 py-2 text-xs transition",
                                        active
                                            ? "bg-gray-900 text-white"
                                            : "border bg-white text-gray-700 hover:bg-gray-50",
                                        (props.loading || value.addr1 === "전체") && "opacity-60"
                                    )}
                                >
                                    {label}
                                </button>
                            );
                        })
                    )}
                </div>
            </div>
            {/* ✅ 업종 */}
            <div className="mt-4">
                <div className="flex items-center justify-between">
                    <div className="text-xs font-semibold text-gray-700">업종</div>
                    <div className="text-[11px] text-gray-500">
                        {value.addr1 === "전체" ? "지역을 먼저 선택하면 더 정확해요" : "선택 시 해당 업종만 표시"}
                    </div>
                </div>

                <div className="mt-2 flex flex-wrap gap-2">
                    {["", ...props.categoryOptions].map((opt) => {
                        const label = opt === "" ? "전체" : opt;
                        const active = value.category === opt;

                        return (
                            <button
                                key={label}
                                type="button"
                                disabled={props.loading}
                                onClick={() => onChange({ ...value, category: opt })}
                                className={[
                                    "rounded-full px-3 py-2 text-xs transition",
                                    active
                                        ? "bg-gray-900 text-white"
                                        : "border bg-white text-gray-700 hover:bg-gray-50",
                                    props.loading ? "opacity-60" : "",
                                ].join(" ")}
                            >
                                {label}
                            </button>
                        );
                    })}
                </div>
            </div>
        </div>
    );
}